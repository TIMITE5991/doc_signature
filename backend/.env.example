# =============================================
# CGRAE Signature - Backend Environment Variables
# =============================================

# App
PORT=3000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=doc_signature

# JWT
JWT_SECRET=your_very_strong_jwt_secret_key_here_min_32_chars
JWT_EXPIRATION=24h

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@cgrae.ci
SMTP_PASSWORD=your_smtp_password_here
EMAIL_FROM=CGRAE Signature <noreply@cgrae.ci>

# CORS
CORS_ORIGIN=http://localhost:4200

# File Upload
UPLOAD_DEST=./uploads
MAX_FILE_SIZE=10485760
